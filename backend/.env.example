# Server
PORT=8000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/centoire

# Auth
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (blank = links logged to console in dev)
RESEND_API_KEY=
MAIL_FROM=Centoire <no-reply@centoire.app>

# RSS ingestion worker
ENABLE_INGESTION=false
INGESTION_CRON=*/30 * * * *
