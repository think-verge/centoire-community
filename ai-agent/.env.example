# Gemini API key from Google AI Studio
GOOGLE_API_KEY=your-gemini-api-key-here

# Node.js backend base URL (for the AI result callback)
NODE_BACKEND_URL=http://localhost:8000

# Shared secret — must match AI_INTERNAL_SECRET in the Node.js backend .env
AI_INTERNAL_SECRET=change-me-in-production

PORT=8001
